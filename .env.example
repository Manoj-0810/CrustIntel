# ══════════════════════════════════════════════════════════════
# CrustIntel — Environment Variables Template
# Copy to .env.local and add your real keys.
# ══════════════════════════════════════════════════════════════

# Claude (Anthropic) — https://console.anthropic.com/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Crustdata — https://crustdata.com
CRUSTDATA_API_KEY=your_crustdata_api_key_here
CRUSTDATA_API_URL=https://api.crustdata.com
CRUSTDATA_API_VERSION=2025-11-01

# Set to true to use live Crustdata APIs (false = mock data demo)
USE_REAL_API=false
